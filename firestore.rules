rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to verify user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // 1. users
    match /users/{uid} {
      // Publicly readable so unauthenticated QR code scans can fetch profile data
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == uid;
    }
    
    // 2. connections
    match /connections/{connectionId} {
      // Allowed if you're in the users array
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      // Creation allowed if creating user is in the array
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.users;
      allow update, delete: if isSignedIn() && request.auth.uid in resource.data.users;
    }

  }
}
