rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to verify user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // 1. users
    match /users/{uid} {
      // Publicly readable so unauthenticated QR code scans can fetch profile data
      allow read: if true;
      // Authenticated user can write to their own document (including password reset updates)
      allow write: if isSignedIn() && request.auth.uid == uid;
      // Allow authenticated users to update their own profile data (for password reset, email updates, etc)
      allow update: if isSignedIn() && request.auth.uid == uid;
    }
    
    // 2. connections
    match /connections/{connectionId} {
      // Allowed if you're the userId or contactUserId
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.contactUserId);
      // Creation allowed if you're the userId
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.contactUserId);
    }

  }
}
